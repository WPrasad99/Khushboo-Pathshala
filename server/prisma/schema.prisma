// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite doesn't support native enums, using strings instead
// enum Role {
//   STUDENT
//   MENTOR
//   ADMIN
// }

// enum ResourceCategory {
//   TECHNICAL_SKILLS
//   SOFT_SKILLS
//   CAREER_GUIDANCE
// }

// enum AchievementType {
//   BADGE
//   PLACEMENT
// }

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String
  name            String
  role            String    @default("STUDENT")
  phone           String?
  gender          String?
  dateOfBirth     DateTime?
  educationLevel  String?
  avatar          String?
  profileCompleted Boolean  @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  uploadedResources   LearningResource[]
  sessionTrackings    SessionTracking[]
  mentorships         Mentorship[]       @relation("MentorRelation")
  menteeships         Mentorship[]       @relation("MenteeRelation")
  forumPosts          ForumPost[]
  forumAnswers        ForumAnswer[]
  achievements        Achievement[]
  announcements       Announcement[]
  activities          Activity[]
  loginLogs           LoginLog[]
  createdGroups       ChatGroup[]        @relation("GroupCreator")
  groupMemberships    GroupMember[]
  chatMessages        ChatMessage[]
  notifications       Notification[]
  batchesAsStudent    BatchStudent[]
  batchesAsMentor     BatchMentor[]
  createdAssignments  Assignment[]       @relation("AssignmentCreator")
  submissions         AssignmentSubmission[]
  reviewedSubmissions AssignmentSubmission[] @relation("SubmissionReviewer")
  
  // Quiz Relations
  createdQuizzes      Quiz[]             @relation("QuizCreator")
  quizSubmissions     QuizSubmission[]
  
  messageReads        MessageRead[]
  messageReactions    MessageReaction[]
}

model LearningResource {
  id            String           @id @default(uuid())
  title         String
  description   String
  category      String
  videoUrl      String
  duration      Int              // Duration in minutes
  thumbnailUrl  String?
  lessonsCount  Int              @default(1)
  lessons       Json?            // Array of { title, videoId, duration }
  isHot         Boolean          @default(false)
  type          String?          // 'SESSION', 'RESOURCE', or 'COURSE' (null = course for backward compatibility)
  batchId       String?          // Association with batch for visibility control
  uploadedById  String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Relations
  uploadedBy        User              @relation(fields: [uploadedById], references: [id])
  batch             Batch?            @relation(fields: [batchId], references: [id])
  sessionTrackings  SessionTracking[]
}

model SessionTracking {
  id                   String   @id @default(uuid())
  userId               String
  resourceId           String
  watchDuration        Int      @default(0)  // Watched duration in seconds
  totalDuration        Int      // Total duration in seconds
  dropOffPoint         Int      @default(0)  // Where user stopped watching (seconds)
  completionPercentage Float    @default(0)
  attendanceMarked     Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  user     User             @relation(fields: [userId], references: [id])
  resource LearningResource @relation(fields: [resourceId], references: [id])
}

model Mentorship {
  id         String   @id @default(uuid())
  mentorId   String
  menteeId   String
  assignedAt DateTime @default(now())

  // Relations
  mentor   User      @relation("MentorRelation", fields: [mentorId], references: [id])
  mentee   User      @relation("MenteeRelation", fields: [menteeId], references: [id])
  meetings Meeting[]
}

model Meeting {
  id                String   @id @default(uuid())
  mentorshipId      String
  meetingDate       DateTime
  duration          Int      // Duration in minutes
  discussionSummary String?
  feedback          String?
  remarks           String?
  createdAt         DateTime @default(now())

  // Relations
  mentorship Mentorship @relation(fields: [mentorshipId], references: [id])
}

model ForumPost {
  id           String   @id @default(uuid())
  title        String
  content      String
  authorId     String
  answersCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  author  User          @relation(fields: [authorId], references: [id])
  answers ForumAnswer[]
}

model ForumAnswer {
  id        String   @id @default(uuid())
  postId    String
  content   String
  authorId  String
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  post   ForumPost @relation(fields: [postId], references: [id])
  author User      @relation(fields: [authorId], references: [id])
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String
  priority  String   @default("normal") // low, normal, high
  createdById String
  createdAt DateTime @default(now())

  // Relations
  createdBy User @relation(fields: [createdById], references: [id])
  batches   AnnouncementBatch[]
}

// Junction table for many-to-many relationship between Announcement and Batch
model AnnouncementBatch {
  id             String   @id @default(uuid())
  announcementId String
  batchId        String
  createdAt      DateTime @default(now())

  // Relations
  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  batch        Batch        @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([announcementId, batchId])
}


model Achievement {
  id          String          @id @default(uuid())
  userId      String
  type        String
  title       String
  description String?
  createdAt   DateTime        @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])
}

model Activity {
  id          String   @id @default(uuid())
  userId      String
  type        String   // watched, completed, placement, achievement
  title       String
  description String?
  createdAt   DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])
}

model Session {
  id          String   @id @default(uuid())
  title       String
  description String?
  scheduledAt DateTime
  duration    Int      // Duration in minutes
  type        String   @default("online") // online, offline
  createdAt   DateTime @default(now())
}

model LoginLog {
  id        String   @id @default(uuid())
  userId    String
  loginDate DateTime @default(now())
  
  // Relations
  user User @relation(fields: [userId], references: [id])
  
  @@index([userId, loginDate])
}

model ChatGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  groupType   String   @default("group") // "direct", "batch", "group"
  batchId     String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  createdBy User          @relation("GroupCreator", fields: [createdById], references: [id])
  batch     Batch?        @relation(fields: [batchId], references: [id])
  members   GroupMember[]
  messages  ChatMessage[]
}

model GroupMember {
  id       String   @id @default(uuid())
  groupId  String
  userId   String
  role     String   @default("member") // admin, member
  status   String   @default("pending") // pending, accepted, rejected
  joinedAt DateTime @default(now())
  
  // Relations
  group ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id])
  
  @@unique([groupId, userId])
}

model ChatMessage {
  id          String   @id @default(uuid())
  groupId     String
  senderId    String
  content     String
  attachments Json?    // Array of {type, url, name, size, mimeType}
  createdAt   DateTime @default(now())
  
  // Relations
  group     ChatGroup         @relation(fields: [groupId], references: [id])
  sender    User              @relation(fields: [senderId], references: [id])
  reads     MessageRead[]
  reactions MessageReaction[]
}

model MessageRead {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())
  
  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])
  
  @@unique([messageId, userId])
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String   // '👍', '❤️', '😂', '😮', '😢', '🙏'
  createdAt DateTime @default(now())
  
  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])
  
  @@unique([messageId, userId, emoji])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("info") // info, success, warning, error
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])
}

model Batch {
  id          String   @id @default(uuid())
  name        String
  description String?
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE, COMPLETED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  students    BatchStudent[]
  mentors     BatchMentor[]
  assignments Assignment[]
  resources   LearningResource[]
  announcements AnnouncementBatch[]
  chatGroups  ChatGroup[]
}

model BatchStudent {
  id        String   @id @default(uuid())
  batchId   String
  studentId String
  joinedAt  DateTime @default(now())

  // Relations
  batch   Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  student User  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([batchId, studentId])
}

model BatchMentor {
  id         String   @id @default(uuid())
  batchId    String
  mentorId   String
  assignedAt DateTime @default(now())

  // Relations
  batch  Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  mentor User  @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  @@unique([batchId, mentorId])
}

model Assignment {
  id          String   @id @default(uuid())
  title       String
  description String
  dueDate     DateTime
  maxMarks    Int      @default(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  createdById String
  createdBy   User     @relation("AssignmentCreator", fields: [createdById], references: [id], onDelete: Cascade)
  batchId     String
  batch       Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  
  submissions AssignmentSubmission[]
}

model AssignmentSubmission {
  id           String   @id @default(uuid())
  content      String
  submittedAt  DateTime @default(now())
  status       String   @default("PENDING")
  marks        Int?
  feedback     String?
  reviewedAt   DateTime?
  
  // Relations
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reviewedById String?
  reviewedBy   User?      @relation("SubmissionReviewer", fields: [reviewedById], references: [id])
  
  @@unique([assignmentId, studentId])
}

model Quiz {
  id          String   @id @default(uuid())
  title       String
  description String?
  duration    Int      // Duration in minutes
  totalMarks  Int
  passingMarks Int?
  dueDate     DateTime?
  batches     Json     // Array of Batch IDs to store which batches can access this quiz
  questions   Json     // Array of { id, question, options: [], correctOption }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  createdById String
  createdBy   User     @relation("QuizCreator", fields: [createdById], references: [id])
  submissions QuizSubmission[]
}

model QuizSubmission {
  id          String   @id @default(uuid())
  quizId      String
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  studentId   String
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers     Json     // { questionId: selectedOption }
  score       Int?
  startedAt   DateTime @default(now())
  submittedAt DateTime?
  status      String   @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, AUTO_SUBMITTED
  
  @@unique([quizId, studentId])
}
